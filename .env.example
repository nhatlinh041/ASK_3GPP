# 3GPP Demo Environment Variables — copy to .env and adjust

# Neo4j connection
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Ollama endpoint — base URL only (no /api/* suffix)
# Use LAN host if Ollama runs on another machine, e.g. http://192.168.1.14:11434
OLLAMA_URL=http://localhost:11434

# RAG engine internal URL (used by NestJS backend)
RAG_ENGINE_URL=http://localhost:8000

# Cloudflared tunnel — set 3 var dưới rồi chạy `bash scripts/gen-cloudflared.sh`
# để sinh cloudflared-demo.yml từ cloudflared-demo.template.yml.
CLOUDFLARED_TUNNEL_ID=your-tunnel-uuid
CLOUDFLARED_CREDENTIALS_FILE=/path/to/your-tunnel-uuid.json
CLOUDFLARED_HOSTNAME=your-domain.com
